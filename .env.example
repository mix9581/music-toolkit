# go-music-dl
GO_MUSIC_DL_URL=http://localhost:8080

# KuGouMusicApi (optional, for full playlist support)
# Enables fetching complete playlists from KuGou (bypasses SSR 10-song limit)
# Start service: docker-compose -f docker-compose.kugou-api.yml up -d
KUGOU_API_URL=http://localhost:3000

# Feishu (optional, required for push commands)
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_DEFAULT_CHAT_ID=oc_xxx

# Download
DOWNLOAD_DIR=./downloads
